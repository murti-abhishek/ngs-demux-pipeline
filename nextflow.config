// ============================================================
// ngs-demux-pipeline | nextflow.config
// ============================================================

manifest {
    name            = 'ngs-demux-pipeline'
    author          = 'Abhishek Murti'
    description     = 'Genetic demultiplexing of pooled snRNA-seq using bulk RNA-seq or WGS/WES genotype data'
    version         = '0.1.0'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
}

// ------------------------------------------------------------
// Default parameters
// ------------------------------------------------------------
params {
    samplesheet  = "${projectDir}/assets/samplesheet.csv"
    genome_fasta = null
    genome_gtf   = null
    n_donors     = null
    star_index   = null
    outdir       = "results"
    help         = false

    // STAR
    star_align_extra_args = '--outSAMtype BAM SortedByCoordinate --outSAMattributes NH HI AS NM MD'

    // GATK
    gatk_hc_extra_args = '--dont-use-soft-clipped-bases --standard-min-confidence-threshold-for-calling 20'

    // Cell Ranger
    cellranger_localcores = 16
    cellranger_localmem   = 64

    // Demuxafy
    demuxlet_field        = 'GT'
    vireo_call_ambient    = true

    // AWS
    aws_region      = 'us-east-1'
    aws_batch_queue = null
    ecr_registry    = null
}

// ------------------------------------------------------------
// Profiles
// ------------------------------------------------------------
profiles {

    local {
        process.executor  = 'local'
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.cpus      = 4
        process.memory    = '16 GB'
    }

    batch {
        process.executor = 'awsbatch'
        process.queue    = params.aws_batch_queue ?: 'nextflow-batch-queue'
        aws.region       = params.aws_region
        aws.batch.cliPath = '/usr/local/bin/aws'
        fusion.enabled   = true
        wave.enabled     = true
        docker.enabled   = true

        process {
            withLabel: 'process_high' {
                cpus   = 16
                memory = '64 GB'
            }
            withLabel: 'process_medium' {
                cpus   = 8
                memory = '32 GB'
            }
            withLabel: 'process_low' {
                cpus   = 2
                memory = '8 GB'
            }
        }
    }

    tower {
        tower.enabled  = true
        tower.endpoint = 'https://api.cloud.seqera.io'
    }
}

// ------------------------------------------------------------
// Container definitions per process label
// ------------------------------------------------------------
process {
    withLabel: 'star_gatk' {
        container = 'murtiabhishek/star-gatk:1.0.0'
    }
    withLabel: 'bcftools' {
        container = 'murtiabhishek/bcftools:1.0.0'
    }
    withLabel: 'cellranger' {
        container = "${params.ecr_registry ?: 'YOUR_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com'}/cellranger:7.2.0"
    }
    withLabel: 'demuxafy' {
        container = "${params.ecr_registry ?: 'YOUR_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com'}/demuxafy:2.0.1"
    }
}

// ------------------------------------------------------------
// Reporting
// ------------------------------------------------------------
report   { enabled = true; file = "${params.outdir}/pipeline_report.html";   overwrite = true }
timeline { enabled = true; file = "${params.outdir}/pipeline_timeline.html"; overwrite = true }
dag      { enabled = true; file = "${params.outdir}/pipeline_dag.html";      overwrite = true }
trace    { enabled = true; file = "${params.outdir}/pipeline_trace.txt";     overwrite = true
           fields = 'task_id,name,status,exit,realtime,cpus,memory,rss' }
