// ============================================================
// ngs-demux-pipeline | nextflow.config
// ============================================================

manifest {
    name            = 'ngs-demux-pipeline'
    author          = 'Abhishek Murti'
    description     = 'Genetic demultiplexing of pooled snRNA-seq using bulk RNA-seq or WGS/WES genotype data'
    version         = '0.1.0'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
}

// ------------------------------------------------------------
// Default parameters
// ------------------------------------------------------------
params {
    samplesheet      = "${projectDir}/assets/samplesheet.csv"
    genome_fasta     = null
    genome_gtf       = null
    n_donors         = null
    star_index       = null
    outdir           = "results"
    help             = false

    // STAR alignment
    star_align_extra_args = '--outSAMtype BAM SortedByCoordinate --outSAMattributes NH HI AS NM MD'

    // GATK
    gatk_hc_extra_args   = '--dont-use-soft-clipped-bases --standard-min-confidence-threshold-for-calling 20'

    // Cell Ranger
    cellranger_localcores  = 16
    cellranger_localmem    = 64

    // Demuxafy tools
    demuxlet_field         = 'GT'
    vireo_call_ambient     = true
    souporcell_min_alt     = 5
    souporcell_min_ref     = 5

    // AWS Batch
    aws_region             = 'us-east-1'
    aws_batch_queue        = null   // set in profiles below
}

// ------------------------------------------------------------
// Profiles
// ------------------------------------------------------------
profiles {

    // Local development / testing
    local {
        process.executor = 'local'
        docker.enabled   = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.cpus     = 4
        process.memory   = '16 GB'
    }

    // AWS Batch (production)
    batch {
        process.executor       = 'awsbatch'
        process.queue          = params.aws_batch_queue ?: 'nextflow-batch-queue'
        aws.region             = params.aws_region
        aws.batch.cliPath      = '/usr/local/bin/aws'

        // Fusion filesystem + Wave containers (no S3 staging overhead)
        fusion.enabled         = true
        wave.enabled           = true

        docker.enabled         = true

        // Per-process resource overrides for Batch
        process {
            withLabel: 'process_high' {
                cpus   = 16
                memory = '64 GB'
            }
            withLabel: 'process_medium' {
                cpus   = 8
                memory = '32 GB'
            }
            withLabel: 'process_low' {
                cpus   = 2
                memory = '8 GB'
            }
        }
    }

    // Seqera Platform (Tower)
    tower {
        tower.enabled    = true
        tower.endpoint   = 'https://api.cloud.seqera.io'
        // TOWER_ACCESS_TOKEN must be set as env var or Tower secret
    }
}

// ------------------------------------------------------------
// Container definitions (per process label)
// Will be overridden per module as images are built
// ------------------------------------------------------------
process {
    withLabel: 'star_gatk' {
        container = 'murtiabhishek/star-gatk:1.0.0'
    }
    withLabel: 'bcftools' {
        container = 'murtiabhishek/bcftools:1.0.0'
    }
    withLabel: 'cellranger' {
        // Private ECR only — not pushed to Docker Hub
        container = "${params.ecr_registry ?: 'YOUR_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com'}/cellranger:7.2.0"
    }
    withLabel: 'demuxafy' {
        // Converted from Demuxafy .sif — private ECR
        container = "${params.ecr_registry ?: 'YOUR_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com'}/demuxafy:2.0.1"
    }
}

// ------------------------------------------------------------
// Execution reporting
// ------------------------------------------------------------
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_timeline.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,cpus,memory,disk,rss,vmem'
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_dag.html"
    overwrite = true
}
