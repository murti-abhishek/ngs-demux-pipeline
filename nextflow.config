// ============================================================
// ngs-demux-pipeline | nextflow.config
// ============================================================

manifest {
    name            = 'ngs-demux-pipeline'
    author          = 'Abhishek Murti'
    description     = 'Genetic demultiplexing of pooled snRNA-seq using bulk RNA-seq or WGS/WES genotype data'
    version         = '0.2.0'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
}

// ------------------------------------------------------------
// Default parameters
// ------------------------------------------------------------
params {
    samplesheet  = "${projectDir}/assets/samplesheet.csv"

    star_index = "s3://nextflow-scrna-abhishek/ngs-demux/reference/star_index_2.7.11b/"
    genome_fasta = "s3://nextflow-scrna-abhishek/ngs-demux/reference/refdata-gex-GRCh38-2020-A/fasta/genome.fa"
    ref_dir      = "s3://nextflow-scrna-abhishek/ngs-demux/reference/refdata-gex-GRCh38-2020-A/"

    n_donors     = null
    outdir = "s3://nextflow-scrna-abhishek/ngs-demux/outputs"
    help         = false

    star_extra_args    = '--outSAMattributes NH HI AS NM MD'
    gatk_hc_extra_args = '--dont-use-soft-clipped-bases --standard-min-confidence-threshold-for-calling 20'

    cellranger_localcores = 16
    cellranger_localmem   = 64

    demuxlet_field     = 'GT'
    vireo_call_ambient = true

    aws_region      = 'us-east-1'
    aws_batch_queue = 'nextflow-batch-queue'
    ecr_registry = "267643289527.dkr.ecr.us-east-1.amazonaws.com"
}

// ------------------------------------------------------------
// Container definitions (applied to all profiles)
// ------------------------------------------------------------
process {
    errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139] || task.exitStatus == -1 ? 'retry' : 'terminate' }
    maxRetries    = 3

    withLabel: 'star_gatk' {
        container = 'murtiabhishek/star-gatk:1.4.0'
    }
    withLabel: 'cellranger' {
        container = "${params.ecr_registry}/cellranger:10.0.2"
    }
    withLabel: 'demuxafy' {
        container = 'murtiabhishek/demuxafy:1.0.0'
    }
}

// ------------------------------------------------------------
// Profiles
// ------------------------------------------------------------
profiles {

    local {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.executor  = 'local'
        process.cpus      = 4
        process.memory    = '8 GB'
    }

    batch {
        docker.enabled    = true
        process.executor  = 'awsbatch'
        process.queue     = params.aws_batch_queue
        aws.region        = params.aws_region
        fusion.enabled    = false
        wave.enabled      = false

        process {
            errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139] || task.exitStatus == -1 ? 'retry' : 'terminate' }
            maxRetries    = 3

            withLabel: 'process_high' {
                cpus   = 8
                memory = '28 GB'
            }
            withLabel: 'process_medium' {
                cpus   = 4
                memory = '8 GB'
            }
            withLabel: 'process_low' {
                cpus   = 2
                memory = '4 GB'
            }
            withName: 'CELLRANGER_COUNT' {
                cpus   = 16
                memory = '60 GB'
            }
            withName: 'SOUPORCELL' {
                cpus   = 8
                memory = '28 GB'
            }
        }
    }

    tower {
        tower.enabled  = true
        tower.endpoint = 'https://api.cloud.seqera.io'
    }
}

// ------------------------------------------------------------
// Reporting
// ------------------------------------------------------------
report   { enabled = true; file = "${params.outdir}/pipeline_report.html";   overwrite = true }
timeline { enabled = true; file = "${params.outdir}/pipeline_timeline.html"; overwrite = true }
dag      { enabled = true; file = "${params.outdir}/pipeline_dag.html";      overwrite = true }
trace    { enabled = true; file = "${params.outdir}/pipeline_trace.txt";     overwrite = true
           fields = 'task_id,name,status,exit,realtime,cpus,memory,rss' }